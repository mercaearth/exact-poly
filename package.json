{
  "name": "exact-poly",
  "version": "0.3.0",
  "description": "Integer polygon geometry library (Rust/WASM) — exact arithmetic, no float errors",
  "main": "./pkg/node/exact_poly.js",
  "types": "./pkg/bundler/exact_poly.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/bundler/exact_poly.d.ts",
      "node": "./pkg/node/exact_poly.js",
      "import": "./pkg/bundler/exact_poly.js",
      "default": "./pkg/bundler/exact_poly.js"
    },
    "./web": {
      "types": "./pkg/web/exact_poly.d.ts",
      "default": "./pkg/web/exact_poly.js"
    }
  },
  "files": [
    "pkg/"
  ],
  "scripts": {
    "build": "bash build.sh",
    "test": "cargo test"
  },
  "keywords": [
    "polygon",
    "geometry",
    "wasm",
    "integer",
    "exact-arithmetic",
    "convex-decomposition",
    "on-chain"
  ],
  "license": "MIT",
  "homepage": "https://exact-poly.merca.earth",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mercaearth/exact-poly.git"
  },
  "bugs": {
    "url": "https://github.com/mercaearth/exact-poly/issues"
  },
  "author": "Gerardus Cremer <dev@merca.earth>"
}
